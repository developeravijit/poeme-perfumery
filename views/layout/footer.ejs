<footer class="relative bg-[#1C1A17] text-white overflow-hidden">
  <!-- Background Glow -->

  <div
    class="absolute -top-32 left-0 w-[400px] h-[400px] rounded-full bg-[#B68D40]/10 blur-[160px]"
  ></div>

  <div
    class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-[#B68D40]/10 blur-[180px]"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-24">
    <div class="grid lg:grid-cols-4 md:grid-cols-2 gap-14">
      <!-- Brand -->

      <div>
        <h2 class="text-5xl font-bold text-white">POÈME</h2>

        <p class="uppercase tracking-[6px] text-[#B68D40] text-sm mt-2">
          Luxury Perfumery
        </p>

        <p class="mt-8 leading-8 text-stone-300">
          Crafted with the world's finest ingredients, POÈME creates timeless
          fragrances that inspire confidence, elegance and unforgettable
          memories.
        </p>

        <!-- Social -->

        <div class="flex gap-4 mt-8">
          <a
            href="#"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-[#B68D40] transition flex items-center justify-center text-xl"
          >
            <i class="fa-brands fa-facebook-f"></i>
          </a>

          <a
            href="#"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-[#B68D40] transition flex items-center justify-center text-xl"
          >
            <i class="fa-brands fa-instagram"></i>
          </a>

          <a
            href="#"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-[#B68D40] transition flex items-center justify-center text-xl"
          >
            <i class="fa-brands fa-x-twitter"></i>
          </a>

          <a
            href="#"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-[#B68D40] transition flex items-center justify-center text-xl"
          >
            <i class="fa-brands fa-linkedin-in"></i>
          </a>
        </div>
      </div>

      <!-- Quick Links -->

      <div>
        <h3 class="text-2xl font-semibold mb-8 text-white">Quick Links</h3>

        <ul class="space-y-4">
          <li>
            <a
              href="#hero"
              class="text-stone-300 hover:text-[#B68D40] transition"
              >Home</a
            >
          </li>

          <li>
            <a
              href="#about"
              class="text-stone-300 hover:text-[#B68D40] transition"
              >About Us</a
            >
          </li>

          <li>
            <a
              href="#collections"
              class="text-stone-300 hover:text-[#B68D40] transition"
              >Collections</a
            >
          </li>

          <li>
            <a
              href="#contact"
              class="text-stone-300 hover:text-[#B68D40] transition"
              >Contact</a
            >
          </li>
        </ul>
      </div>

      <!-- Collections -->

      <div>
        <h3 class="text-2xl font-semibold mb-8 text-white">Collections</h3>

        <ul class="space-y-4">
          <li>
            <a href="#" class="text-stone-300 hover:text-[#B68D40] transition"
              >Royal Series</a
            >
          </li>

          <li>
            <a href="#" class="text-stone-300 hover:text-[#B68D40] transition"
              >Oud Collection</a
            >
          </li>

          <li>
            <a href="#" class="text-stone-300 hover:text-[#B68D40] transition"
              >Floral Essence</a
            >
          </li>

          <li>
            <a href="#" class="text-stone-300 hover:text-[#B68D40] transition"
              >Limited Edition</a
            >
          </li>
        </ul>
      </div>

      <!-- Newsletter -->

      <div>
        <h3 class="text-2xl font-semibold mb-8 text-white">Stay Connected</h3>

        <p class="text-stone-300 leading-8">
          Subscribe to receive exclusive offers, new launches and luxury
          fragrance updates.
        </p>

        <form class="mt-8">
          <input
            type="email"
            placeholder="Enter your email"
            class="w-full rounded-full bg-white/10 border border-white/10 px-6 py-4 outline-none focus:border-[#B68D40] placeholder:text-stone-400"
          />

          <button
            class="w-full mt-4 rounded-full bg-[#B68D40] hover:bg-[#9C7834] transition py-4 font-semibold"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom -->

    <div class="mt-20 pt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-stone-400 text-center md:text-left">
          © <%= new Date().getFullYear() %> POÈME Perfumery. All Rights
          Reserved.
        </p>

        <div class="flex gap-8">
          <a href="#" class="text-stone-400 hover:text-[#B68D40] transition">
            Privacy Policy
          </a>

          <a href="#" class="text-stone-400 hover:text-[#B68D40] transition">
            Terms & Conditions
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
