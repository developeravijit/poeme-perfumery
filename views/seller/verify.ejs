<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Seller Account</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
  </head>

  <body
    class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950"
  >
    <!-- Background -->
    <div
      class="absolute top-0 left-0 w-96 h-96 bg-indigo-600/20 blur-3xl rounded-full"
    ></div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 bg-purple-600/20 blur-3xl rounded-full"
    ></div>

    <div
      class="relative min-h-screen flex items-center justify-center px-5 py-10"
    >
      <div
        class="max-w-5xl w-full bg-white rounded-3xl overflow-hidden shadow-2xl grid lg:grid-cols-2"
      >
        <!-- Left -->
        <div
          class="hidden lg:flex flex-col justify-between bg-gradient-to-br from-indigo-700 via-indigo-600 to-purple-700 text-white p-12"
        >
          <div>
            <h1 class="text-4xl font-bold">Verify Your Account</h1>

            <p class="mt-5 text-indigo-100 leading-7">
              We've sent a One-Time Password (OTP) to your registered email
              address. Enter the OTP to activate your seller account.
            </p>
          </div>

          <div class="space-y-5">
            <div class="flex items-center gap-4">
              <div
                class="w-11 h-11 rounded-xl bg-white/20 flex items-center justify-center"
              >
                <i class="fa-solid fa-envelope"></i>
              </div>

              <span>Email Verification</span>
            </div>

            <div class="flex items-center gap-4">
              <div
                class="w-11 h-11 rounded-xl bg-white/20 flex items-center justify-center"
              >
                <i class="fa-solid fa-shield-halved"></i>
              </div>

              <span>Secure Authentication</span>
            </div>

            <div class="flex items-center gap-4">
              <div
                class="w-11 h-11 rounded-xl bg-white/20 flex items-center justify-center"
              >
                <i class="fa-solid fa-user-check"></i>
              </div>

              <span>Activate Seller Account</span>
            </div>
          </div>

          <p class="text-indigo-100 text-sm">
            Secure verification protects your seller account.
          </p>
        </div>

        <!-- Right -->
        <div class="p-8 lg:p-12">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="text-3xl font-bold text-slate-800">
                OTP Verification
              </h2>

              <p class="text-slate-500 mt-2">
                Enter the 6-digit OTP sent to your email.
              </p>
            </div>

            <a
              href="/poeme-perfumery/seller/login"
              class="text-indigo-600 font-semibold hover:text-indigo-700"
            >
              Login
            </a>
          </div>

          <!-- Success -->

          <% if(success.length){ %>

          <div
            class="mt-6 rounded-xl bg-green-100 border border-green-300 text-green-700 px-4 py-3"
          >
            <%= success[0] %>
          </div>

          <% } %>

          <!-- Error -->

          <% if(error.length){ %>

          <div
            class="mt-6 rounded-xl bg-red-100 border border-red-300 text-red-700 px-4 py-3"
          >
            <%= error[0] %>
          </div>

          <% } %>

          <form
            action="/poeme-perfumery/seller/verify"
            method="POST"
            class="mt-8 space-y-6"
          >
            <div>
              <label class="text-sm font-medium text-slate-700">
                Enter OTP
              </label>

              <div class="relative mt-2">
                <i
                  class="fa-solid fa-key absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"
                ></i>

                <input
                  type="text"
                  name="otp"
                  maxlength="6"
                  minlength="6"
                  required
                  autocomplete="one-time-code"
                  placeholder="Enter 6-digit OTP"
                  class="w-full h-12 pl-11 rounded-xl border border-slate-300 focus:border-indigo-600 focus:ring-4 focus:ring-indigo-100 outline-none tracking-[0.35em] text-center text-lg font-semibold"
                />
              </div>
            </div>

            <button
              class="w-full h-12 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold transition"
            >
              Verify Account
            </button>
          </form>

          <div class="mt-8 text-center text-slate-600">
            Didn't receive the OTP?

            <a
              href="/poeme-perfumery/seller/resend-otp"
              class="text-indigo-600 font-semibold hover:underline"
            >
              Resend OTP
            </a>
          </div>

          <div class="mt-6 text-center">
            <a
              href="/poeme-perfumery/seller/register"
              class="text-sm text-slate-500 hover:text-indigo-600"
            >
              ← Back to Register
            </a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
