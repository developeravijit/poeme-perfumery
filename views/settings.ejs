<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Account Settings | POÈME Perfumery</title>

    <link rel="stylesheet" href="/css/output.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#FCFBF8]">
    <%- include("layout/navbar.ejs") %>

    <!-- ================= Hero ================= -->

    <section
      class="pt-36 pb-20 bg-gradient-to-b from-[#F8F3EA] to-[#FCFBF8] relative overflow-hidden"
    >
      <div
        class="absolute -top-32 left-0 w-[450px] h-[450px] rounded-full bg-[#F3E7D0] blur-[170px] opacity-70"
      ></div>

      <div
        class="absolute -bottom-32 right-0 w-[400px] h-[400px] rounded-full bg-[#EFE2C9] blur-[170px] opacity-70"
      ></div>

      <div class="relative max-w-7xl mx-auto px-6 text-center">
        <p class="uppercase tracking-[8px] text-[#B68D40] font-semibold">
          Your Account
        </p>

        <h1 class="mt-4 text-6xl font-bold text-stone-900">Account Settings</h1>

        <p class="mt-6 max-w-2xl mx-auto text-lg text-stone-600 leading-8">
          Manage your personal information, password, addresses and account
          preferences from one place.
        </p>
      </div>
    </section>

    <!-- ================= Main ================= -->

    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-10">
          <!-- ================= Sidebar ================= -->

          <aside class="lg:col-span-4">
            <div
              class="sticky top-28 bg-white rounded-[32px] border border-stone-200 shadow-lg overflow-hidden"
            >
              <!-- Header -->

              <div
                class="bg-gradient-to-r from-[#B68D40] to-[#D8B86A] px-8 py-10 text-center"
              >
                <div
                  class="w-28 h-28 rounded-full bg-white mx-auto flex items-center justify-center text-4xl font-bold text-[#B68D40]"
                >
                  <%= user.name.charAt(0).toUpperCase() %>
                </div>

                <h2 class="mt-6 text-3xl font-semibold text-white">
                  <%= user.name %>
                </h2>

                <p class="mt-2 text-[#FFF5E3]"><%= user.email %></p>
              </div>

              <!-- Body -->

              <div class="p-8">
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <span class="text-stone-500"> Member Since </span>

                    <span class="font-semibold text-stone-900">
                      <%= new Date(user.createdAt).toLocaleDateString("en-IN")
                      %>
                    </span>
                  </div>

                  <div class="flex items-center justify-between">
                    <span class="text-stone-500"> Phone </span>

                    <span class="font-semibold">
                      <%= user.phone || "Not Added" %>
                    </span>
                  </div>

                  <div class="flex items-center justify-between">
                    <span class="text-stone-500"> Provider </span>

                    <span
                      class="bg-[#F5E9D5] text-[#B68D40] px-3 py-1 rounded-full font-semibold"
                    >
                      <%= user.provider === "google" ? "Google" : "Local" %>
                    </span>
                  </div>

                  <div class="flex items-center justify-between">
                    <span class="text-stone-500"> Status </span>

                    <% if(user.isVerified){ %>

                    <span
                      class="bg-green-100 text-green-700 px-4 py-1 rounded-full text-sm font-semibold"
                    >
                      Verified
                    </span>

                    <% }else{ %>

                    <span
                      class="bg-red-100 text-red-600 px-4 py-1 rounded-full text-sm font-semibold"
                    >
                      Not Verified
                    </span>

                    <% } %>
                  </div>

                  <div class="flex items-center justify-between">
                    <span class="text-stone-500"> Account </span>

                    <% if(user.isActive){ %>

                    <span
                      class="bg-green-100 text-green-700 px-4 py-1 rounded-full text-sm font-semibold"
                    >
                      Active
                    </span>

                    <% } else { %>

                    <span
                      class="bg-red-100 text-red-600 px-4 py-1 rounded-full text-sm font-semibold"
                    >
                      Disabled
                    </span>

                    <% } %>
                  </div>
                </div>

                <hr class="my-8" />

                <div class="space-y-3">
                  <a
                    href="#profile"
                    class="flex items-center justify-between px-5 py-4 rounded-2xl bg-[#F8F3EA] text-[#B68D40] font-semibold"
                  >
                    Personal Information

                    <span>→</span>
                  </a>

                  <% if(user.provider === "local"){ %>

                  <a
                    href="#password"
                    class="flex items-center justify-between px-5 py-4 rounded-2xl hover:bg-stone-100 transition"
                  >
                    Change Password
                    <span>→</span>
                  </a>

                  <% } %>

                  <a
                    href="#address"
                    class="flex items-center justify-between px-5 py-4 rounded-2xl hover:bg-stone-100 transition"
                  >
                    Address Book

                    <span>→</span>
                  </a>
                </div>
              </div>
            </div>
          </aside>

          <!-- ================= Content ================= -->

          <main class="lg:col-span-8">
            <div
              id="profile"
              class="bg-white rounded-[32px] border border-stone-200 shadow-lg p-10"
            >
              <div class="flex items-center justify-between">
                <div>
                  <p
                    class="uppercase tracking-[6px] text-[#B68D40] font-semibold"
                  >
                    Profile
                  </p>

                  <h2 class="mt-3 text-4xl font-bold">Personal Information</h2>

                  <p class="mt-3 text-stone-500">
                    Update your personal information and keep your account
                    details up to date.
                  </p>
                </div>
              </div>

              <form
                action="/poeme-perfumery/settings/profile"
                method="POST"
                class="mt-10"
              >
                <div class="grid md:grid-cols-2 gap-8">
                  <!-- Full Name -->

                  <div>
                    <label class="block mb-3 font-medium text-stone-700">
                      Full Name
                    </label>

                    <input
                      type="text"
                      name="name"
                      value="<%= user.name %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                      required
                    />
                  </div>

                  <!-- Email -->

                  <div>
                    <label class="block mb-3 font-medium text-stone-700">
                      Email Address
                    </label>

                    <input
                      type="email"
                      value="<%= user.email %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                      readonly
                    />
                  </div>

                  <!-- Phone -->

                  <div>
                    <label class="block mb-3 font-medium text-stone-700">
                      Phone Number
                    </label>

                    <input
                      type="tel"
                      name="phone"
                      value="<%= user.phone || '' %>"
                      placeholder="Enter phone number"
                      maxlength="10"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    />
                  </div>
                </div>

                <!-- Buttons -->

                <div class="flex gap-4 mt-10">
                  <button
                    type="submit"
                    class="bg-[#B68D40] hover:bg-[#9D7A37] text-white px-10 py-4 rounded-full font-semibold transition"
                  >
                    Save Changes
                  </button>

                  <button
                    type="reset"
                    class="border border-stone-300 px-10 py-4 rounded-full hover:bg-stone-100 transition"
                  >
                    Reset
                  </button>
                </div>
              </form>
            </div>

            <% if(user.provider === "local"){ %>

            <div
              id="password"
              class="mt-10 bg-white rounded-[32px] border border-stone-200 shadow-lg p-10"
            >
              <div>
                <p
                  class="uppercase tracking-[6px] text-[#B68D40] font-semibold"
                >
                  Security
                </p>

                <h2 class="mt-3 text-4xl font-bold text-stone-900">
                  Change Password
                </h2>

                <p class="mt-3 text-stone-500">
                  Keep your account secure by updating your password regularly.
                </p>
              </div>

              <form
                action="/poeme-perfumery/settings/password"
                method="POST"
                class="mt-10 space-y-8"
              >
                <div>
                  <label class="block mb-3 font-medium text-stone-700">
                    Current Password
                  </label>

                  <input
                    type="password"
                    name="currentPassword"
                    placeholder="Enter current password"
                    class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    required
                  />
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                  <div>
                    <label class="block mb-3 font-medium text-stone-700">
                      New Password
                    </label>

                    <input
                      type="password"
                      name="newPassword"
                      placeholder="Enter new password"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                      required
                    />
                  </div>

                  <div>
                    <label class="block mb-3 font-medium text-stone-700">
                      Confirm Password
                    </label>

                    <input
                      type="password"
                      name="confirmPassword"
                      placeholder="Confirm password"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                      required
                    />
                  </div>
                </div>

                <button
                  type="submit"
                  class="bg-[#B68D40] hover:bg-[#9D7A37] text-white px-10 py-4 rounded-full font-semibold transition"
                >
                  Update Password
                </button>
              </form>
            </div>
            <% } %>

            <!-- ================= Address ================= -->

            <div
              id="address"
              class="mt-10 bg-white rounded-[32px] border border-stone-200 shadow-lg p-10"
            >
              <div>
                <p
                  class="uppercase tracking-[6px] text-[#B68D40] font-semibold"
                >
                  Delivery
                </p>

                <h2 class="mt-3 text-4xl font-bold">Shipping Address</h2>
              </div>

              <form
                action="/poeme-perfumery/settings/address"
                method="POST"
                class="mt-10"
              >
                <div class="grid md:grid-cols-2 gap-8">
                  <div>
                    <label class="block mb-3 font-medium"> Address Line </label>

                    <input
                      type="text"
                      name="street"
                      value="<%= user.address?.street || '' %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    />
                  </div>

                  <div>
                    <label class="block mb-3 font-medium"> City </label>

                    <input
                      type="text"
                      name="city"
                      value="<%= user.address?.city || '' %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    />
                  </div>

                  <div>
                    <label class="block mb-3 font-medium"> State </label>

                    <input
                      type="text"
                      name="state"
                      value="<%= user.address?.state || '' %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    />
                  </div>

                  <div>
                    <label class="block mb-3 font-medium"> Pincode </label>

                    <input
                      type="text"
                      name="pincode"
                      value="<%= user.address?.pincode || '' %>"
                      class="w-full rounded-2xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
                    />
                  </div>
                </div>

                <button
                  type="submit"
                  class="mt-10 bg-[#B68D40] hover:bg-[#9D7A37] text-white px-10 py-4 rounded-full font-semibold"
                >
                  Save Address
                </button>
              </form>
            </div>
          </main>
        </div>
      </div>
    </section>

    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-6">
        <div
          class="rounded-[36px] bg-gradient-to-r from-[#B68D40] to-[#D9B96A] px-10 py-16 text-center text-white"
        >
          <p class="uppercase tracking-[8px] text-white/80">
            Luxury Fragrance Experience
          </p>

          <h2 class="mt-5 text-5xl font-bold">Thank You For Choosing POÈME</h2>

          <p class="mt-6 max-w-3xl mx-auto text-lg text-white/90 leading-8">
            We are committed to delivering timeless fragrances and an
            exceptional shopping experience. Your account helps us personalize
            recommendations and provide seamless service.
          </p>

          <a
            href="/poeme-perfumery/perfumes"
            class="inline-block mt-10 bg-white text-[#B68D40] hover:bg-[#F8F3EA] px-10 py-4 rounded-full font-semibold transition"
          >
            Continue Shopping
          </a>
        </div>
      </div>
    </section>

    <%- include("layout/footer.ejs") %>

    <script src="/js/index.js"></script>
  </body>
</html>
