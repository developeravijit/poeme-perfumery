<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Orders | POÈME Perfumery</title>

    <link rel="stylesheet" href="/css/output.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#FCFBF8]">
    <%- include("layout/navbar.ejs") %>

    <!-- Hero -->

    <section
      class="pt-36 pb-16 bg-gradient-to-b from-[#F8F3EA] to-[#FCFBF8] relative overflow-hidden"
    >
      <div
        class="absolute -top-32 left-0 w-[450px] h-[450px] rounded-full bg-[#F3E7D0] blur-[170px] opacity-70"
      ></div>

      <div
        class="absolute -bottom-40 right-0 w-[400px] h-[400px] rounded-full bg-[#EFE2C9] blur-[170px] opacity-70"
      ></div>

      <div class="relative max-w-7xl mx-auto px-6 text-center">
        <p class="uppercase tracking-[8px] text-[#B68D40] font-semibold">
          Purchase History
        </p>

        <h1 class="mt-4 text-6xl font-bold text-stone-900">My Orders</h1>

        <p class="mt-6 text-lg text-stone-600 max-w-2xl mx-auto">
          View your previous perfume purchases, track deliveries, and reorder
          your favourite fragrances anytime.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
      <% if(orders.length){ %>

      <div class="space-y-10">
        <% orders.forEach(order=>{ %>

        <div
          class="bg-white rounded-[30px] shadow-lg border border-stone-200 overflow-hidden"
        >
          <!-- Header -->

          <div
            class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 px-8 py-6 border-b border-stone-200"
          >
            <div>
              <h2 class="text-3xl font-semibold text-stone-900">
                Order #<%= order.orderId %>
              </h2>

              <div class="mt-3 flex flex-wrap gap-6 text-sm text-stone-500">
                <p>
                  Ordered :
                  <%= new
                  Date(order.createdAt).toLocaleDateString("en-IN") %>
                </p>

                <p>Payment : <%= order.paymentMethod %></p>
              </div>
            </div>

            <% if(order.status==="Delivered"){ %>

            <span
              class="px-5 py-3 rounded-full bg-green-100 text-green-700 font-semibold"
            >
              Delivered
            </span>

            <% } else if(order.status==="Processing"){ %>

            <span
              class="px-5 py-3 rounded-full bg-yellow-100 text-yellow-700 font-semibold"
            >
              Processing
            </span>

            <% } else if(order.status==="Shipped"){ %>

            <span
              class="px-5 py-3 rounded-full bg-blue-100 text-blue-700 font-semibold"
            >
              Shipped
            </span>

            <% } else { %>

            <span
              class="px-5 py-3 rounded-full bg-red-100 text-red-600 font-semibold"
            >
              Cancelled
            </span>

            <% } %>
          </div>

          <!-- Products -->

          <div class="divide-y divide-stone-200">
            <% order.items.forEach(item=>{ %>

            <div class="p-8 flex flex-col lg:flex-row gap-8">
              <!-- Image -->

              <div
                class="w-full lg:w-52 h-52 bg-[#F8F6F2] rounded-3xl flex items-center justify-center"
              >
                <img
                  src="/assets/<%= item.product.image %>"
                  class="max-h-44 object-contain"
                />
              </div>

              <!-- Details -->

              <div class="flex-1">
                <p
                  class="uppercase tracking-[4px] text-sm text-[#B68D40] font-semibold"
                >
                  <%= item.product.brand %>
                </p>

                <h3 class="mt-2 text-4xl font-semibold text-stone-900">
                  <%= item.product.name %>
                </h3>

                <p class="mt-4 text-stone-500 leading-7">
                  <%= item.product.description %>
                </p>

                <div class="grid md:grid-cols-3 gap-6 mt-8">
                  <div>
                    <p class="text-sm text-stone-500">Quantity</p>

                    <h4 class="text-xl font-semibold mt-1">
                      <%= item.quantity %>
                    </h4>
                  </div>

                  <div>
                    <p class="text-sm text-stone-500">Unit Price</p>

                    <h4 class="text-xl font-semibold mt-1">
                      ₹<%= item.price.toLocaleString("en-IN") %>
                    </h4>
                  </div>

                  <div>
                    <p class="text-sm text-stone-500">Total</p>

                    <h4 class="text-2xl font-bold text-[#B68D40] mt-1">
                      ₹<%= (item.price*item.quantity).toLocaleString("en-IN") %>
                    </h4>
                  </div>
                </div>
              </div>
            </div>

            <% }) %>
          </div>

          <!-- Summary -->

          <div class="bg-[#FCFBF8] px-8 py-8">
            <div class="grid lg:grid-cols-2 gap-10">
              <div>
                <h3 class="text-2xl font-semibold">Shipping Address</h3>

                <p class="mt-5 text-stone-600 leading-8">
                  <%= order.shippingAddress.name %><br />

                  <%= order.shippingAddress.street %><br />

                  <%= order.shippingAddress.city %>,
                  <%= order.shippingAddress.state %><br />

                  <%= order.shippingAddress.pincode %>
                </p>
              </div>

              <div>
                <div class="space-y-4">
                  <div class="flex justify-between">
                    <span>Subtotal</span>

                    <span>
                      ₹<%= order.subtotal.toLocaleString("en-IN") %>
                    </span>
                  </div>

                  <div class="flex justify-between">
                    <span>Shipping</span>

                    <span>
                      ₹<%= order.shipping.toLocaleString("en-IN") %>
                    </span>
                  </div>

                  <div class="flex justify-between">
                    <span>Tax</span>

                    <span> ₹<%= order.tax.toLocaleString("en-IN") %> </span>
                  </div>

                  <hr />

                  <div class="flex justify-between text-2xl font-bold">
                    <span>Total</span>

                    <span class="text-[#B68D40]">
                      ₹<%= order.total.toLocaleString("en-IN") %>
                    </span>
                  </div>
                </div>

                <div class="mt-8 flex flex-wrap gap-4">
                  <a
                    href="/poeme-perfumery/orders/<%= order._id %>"
                    class="bg-[#B68D40] hover:bg-[#9A7737] text-white px-8 py-4 rounded-full font-semibold"
                  >
                    View Details
                  </a>

                  <a
                    href="/poeme-perfumery/order-again/<%= order._id %>"
                    class="border border-[#B68D40] text-[#B68D40] px-8 py-4 rounded-full hover:bg-[#B68D40] hover:text-white"
                  >
                    Buy Again
                  </a>

                  <% if(order.status==="Processing"){ %>

                  <a
                    href="/poeme-perfumery/orders/cancel/<%= order._id %>"
                    class="border border-red-300 text-red-600 px-8 py-4 rounded-full hover:bg-red-50"
                  >
                    Cancel Order
                  </a>

                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <% }) %>
      </div>

      <% } else { %>

      <!-- Empty Orders -->

      <div
        class="bg-white rounded-[32px] border border-stone-200 shadow-lg p-20 text-center"
      >
        <div
          class="w-40 h-40 rounded-full bg-[#F8F3EA] flex items-center justify-center mx-auto"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-20 h-20 text-[#B68D40]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 7h18M5 7l1 13h12l1-13M9 7V4h6v3"
            />
          </svg>
        </div>

        <h2 class="mt-10 text-5xl font-bold text-stone-900">No Orders Yet</h2>

        <p class="mt-5 text-lg text-stone-500 max-w-xl mx-auto leading-8">
          You haven't purchased any fragrances yet. Discover our luxury perfume
          collection and place your first order.
        </p>

        <a
          href="/poeme-perfumery/perfumes"
          class="inline-block mt-10 bg-[#B68D40] hover:bg-[#9A7737] text-white px-10 py-4 rounded-full font-semibold transition"
        >
          Explore Collection
        </a>
      </div>

      <% } %>
    </section>

    <!-- Recommended Section -->

    <% if(orders.length){ %>

    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center">
          <p class="uppercase tracking-[8px] text-[#B68D40] font-semibold">
            Continue Shopping
          </p>

          <h2 class="mt-4 text-5xl font-bold text-stone-900">
            Discover More Luxury Fragrances
          </h2>

          <p class="mt-5 text-stone-500 max-w-2xl mx-auto">
            Explore our latest arrivals and timeless collections, crafted to
            leave a lasting impression.
          </p>

          <a
            href="/poeme-perfumery/perfumes"
            class="inline-block mt-10 border border-[#B68D40] text-[#B68D40] hover:bg-[#B68D40] hover:text-white px-10 py-4 rounded-full font-semibold transition"
          >
            Shop More
          </a>
        </div>
      </div>
    </section>

    <% } %>

    <%- include("layout/footer.ejs") %>

    <script src="/js/index.js"></script>
  </body>
</html>
