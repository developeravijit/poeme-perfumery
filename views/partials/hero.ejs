<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-[#FCFBF8] via-[#F8F6F2] to-[#F2ECE2] pt-40 pb-24"
>
  <!-- Background Blur -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute -top-44 -left-40 w-[600px] h-[600px] rounded-full bg-[#EADCC0] opacity-60 blur-[170px]"
    ></div>

    <div
      class="absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full bg-[#F6EAD4] opacity-80 blur-[170px]"
    ></div>

    <div
      class="absolute top-1/3 right-1/4 w-52 h-52 rounded-full border border-[#C8A96B]/20"
    ></div>

    <div
      class="absolute bottom-24 left-24 w-36 h-36 rounded-full border border-[#C8A96B]/15"
    ></div>
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-8 grid lg:grid-cols-2 gap-24 items-center"
  >
    <!-- Left Content -->
    <div>
      <p
        class="uppercase tracking-[10px] text-[#B68D40] font-semibold text-sm mb-6"
      >
        Luxury Collection
      </p>

      <h1
        class="text-5xl md:text-6xl lg:text-8xl font-bold leading-[1.05] text-stone-900"
      >
        Luxury

        <span class="block text-[#B68D40]"> Has Its Own </span>

        Fragrance.
      </h1>

      <p class="mt-8 max-w-xl text-lg leading-9 text-stone-600">
        Discover handcrafted fragrances inspired by timeless elegance, rare
        ingredients, and unforgettable memories. Every bottle is created to
        reflect sophistication, confidence, and lasting luxury.
      </p>

      <div class="flex flex-wrap gap-5 mt-12">
        <a
          href="#collections"
          class="px-9 py-4 rounded-full bg-[#B68D40] text-white font-semibold shadow-xl shadow-[#B68D40]/20 hover:bg-[#9D7A37] hover:-translate-y-1 transition-all duration-300"
        >
          Explore Collection
        </a>

        <a
          href="#"
          class="px-9 py-4 rounded-full bg-white border border-stone-300 text-stone-800 font-medium shadow-md hover:bg-stone-100 transition"
        >
          Our Story
        </a>
      </div>

      <!-- Features -->
      <div class="grid grid-cols-3 gap-10 mt-20">
        <div>
          <h2 class="text-3xl font-bold text-[#B68D40]">50+</h2>

          <p class="mt-2 text-stone-600">Premium Fragrances</p>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-[#B68D40]">15K+</h2>

          <p class="mt-2 text-stone-600">Happy Customers</p>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-[#B68D40]">100%</h2>

          <p class="mt-2 text-stone-600">Authentic Quality</p>
        </div>
      </div>
    </div>

    <!-- Right Image -->
    <div class="relative flex justify-center">
      <!-- Glow -->
      <div
        class="absolute w-[420px] h-[420px] rounded-full bg-[#D8C39A]/50 blur-[130px]"
      ></div>

      <!-- Decorative Ring -->
      <div
        class="absolute w-[470px] h-[470px] rounded-full border border-[#D9BE84]/40"
      ></div>

      <div
        class="absolute w-[560px] h-[560px] rounded-full border border-[#E8D9B8]/30"
      ></div>

      <!-- Image Card -->
      <div
        class="relative bg-white rounded-[40px] shadow-2xl shadow-stone-300/40 p-10"
      >
        <img
          src="/assets/banner.png"
          alt="Luxury Perfume"
          class="relative z-10 h-[650px] w-auto object-contain transition duration-700 hover:scale-105"
        />
      </div>

      <!-- Floating Badge -->
      <div
        class="absolute top-8 left-8 bg-white/95 backdrop-blur-md rounded-2xl px-6 py-4 shadow-2xl border border-stone-100 z-30"
      >
        <p
          class="text-xs uppercase tracking-[5px] text-[#B68D40] font-semibold"
        >
          Premium
        </p>

        <h3 class="text-2xl font-semibold text-stone-900 mt-1">Since 1998</h3>
      </div>

      <!-- Floating Card -->
      <div
        class="absolute bottom-8 right-8 bg-white/95 backdrop-blur-md rounded-2xl px-7 py-5 shadow-2xl border border-stone-100 z-30"
      >
        <p class="text-xs uppercase tracking-[3px] text-stone-500">
          Bestseller
        </p>

        <h3 class="text-xl font-semibold text-[#B68D40] mt-1">Luxury Oud</h3>
      </div>
    </div>
  </div>
</section>
