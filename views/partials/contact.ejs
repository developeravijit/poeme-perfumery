<section id="contact" class="relative py-28 bg-[#FCFBF8] overflow-hidden">
  <!-- Background -->

  <div
    class="absolute -top-40 -left-32 w-[500px] h-[500px] rounded-full bg-[#F3E7D1] blur-[180px] opacity-70"
  ></div>

  <div
    class="absolute -bottom-40 -right-32 w-[450px] h-[450px] rounded-full bg-[#F6EEDC] blur-[180px] opacity-80"
  ></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Heading -->

    <div class="text-center max-w-3xl mx-auto">
      <span class="uppercase tracking-[8px] text-[#B68D40] font-semibold">
        Contact Us
      </span>

      <h2 class="mt-4 text-5xl lg:text-6xl font-bold text-stone-900">
        We'd Love To Hear From You
      </h2>

      <p class="mt-6 text-lg leading-8 text-stone-600">
        Whether you have a question about our fragrances, your order, or need
        personalized recommendations, our team is always ready to help.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start mt-20">
      <!-- Contact Info -->

      <div class="space-y-8">
        <!-- Address -->

        <div class="bg-white rounded-3xl p-8 border border-stone-200 shadow-lg">
          <div
            class="w-16 h-16 rounded-full bg-[#F6EAD4] flex items-center justify-center text-3xl"
          >
            📍
          </div>

          <h3 class="mt-6 text-3xl font-semibold text-stone-900">
            Visit Our Store
          </h3>

          <p class="mt-4 text-stone-600 leading-8">
            123 Luxury Avenue<br />

            Park Street<br />

            Kolkata, India
          </p>
        </div>

        <!-- Phone -->

        <div class="bg-white rounded-3xl p-8 border border-stone-200 shadow-lg">
          <div
            class="w-16 h-16 rounded-full bg-[#F6EAD4] flex items-center justify-center text-3xl"
          >
            📞
          </div>

          <h3 class="mt-6 text-3xl font-semibold text-stone-900">Call Us</h3>

          <p class="mt-4 text-stone-600">+91 98765 43210</p>

          <p class="text-stone-600">Mon - Sat (10 AM - 8 PM)</p>
        </div>

        <!-- Email -->

        <div class="bg-white rounded-3xl p-8 border border-stone-200 shadow-lg">
          <div
            class="w-16 h-16 rounded-full bg-[#F6EAD4] flex items-center justify-center text-3xl"
          >
            ✉️
          </div>

          <h3 class="mt-6 text-3xl font-semibold text-stone-900">Email</h3>

          <p class="mt-4 text-stone-600">support@poeme.com</p>

          <p class="text-stone-600">contact@poeme.com</p>
        </div>
      </div>

      <!-- Contact Form -->

      <div
        class="bg-white rounded-[40px] shadow-2xl border border-stone-200 p-10 max-w-2xl w-full mx-auto"
      >
        <form action="#" method="POST" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block mb-2 text-stone-700 font-medium">
                Full Name
              </label>

              <input
                type="text"
                placeholder="John Doe"
                class="w-full rounded-xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
              />
            </div>

            <div>
              <label class="block mb-2 text-stone-700 font-medium">
                Email Address
              </label>

              <input
                type="email"
                placeholder="john@example.com"
                class="w-full rounded-xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
              />
            </div>
          </div>

          <div>
            <label class="block mb-2 text-stone-700 font-medium">
              Subject
            </label>

            <input
              type="text"
              placeholder="How can we help?"
              class="w-full rounded-xl border border-stone-300 px-5 py-4 outline-none focus:border-[#B68D40]"
            />
          </div>

          <div>
            <label class="block mb-2 text-stone-700 font-medium">
              Message
            </label>

            <textarea
              rows="6"
              placeholder="Write your message..."
              class="w-full rounded-xl border border-stone-300 px-5 py-4 outline-none resize-none focus:border-[#B68D40]"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#B68D40] hover:bg-[#9C7834] text-white py-4 rounded-xl font-semibold transition"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
