<section id="collections" class="relative overflow-hidden bg-[#FCFBF8] py-28">
  <!-- Background -->
  <div
    class="absolute -top-44 -left-32 w-[550px] h-[550px] rounded-full bg-[#F3E8D3] blur-[180px] opacity-70"
  ></div>

  <div
    class="absolute bottom-0 right-0 w-[450px] h-[450px] rounded-full bg-[#F7EFD9] blur-[170px] opacity-80"
  ></div>

  <div class="relative max-w-7xl mx-auto px-8">
    <!-- Heading -->
    <div class="text-center mb-20">
      <p class="uppercase tracking-[8px] text-[#B68D40] font-semibold">
        Premium Collection
      </p>

      <h2 class="mt-4 text-5xl lg:text-6xl font-bold text-stone-900">
        Signature Fragrances
      </h2>

      <p class="mt-6 max-w-3xl mx-auto text-stone-500 leading-8 text-lg">
        Explore our carefully curated luxury perfumes crafted from premium
        ingredients, timeless elegance, and unforgettable aromas.
      </p>
    </div>

    <% if(products && products.length > 0){ %>

    <div class="swiper collectionSwiper">
      <div class="swiper-wrapper">
        <% products.forEach(item => { %>

        <div class="swiper-slide">
          <div
            class="group bg-white rounded-[32px] border border-stone-200 shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden"
          >
            <!-- Product Image -->
            <div
              class="relative h-[380px] flex items-center justify-center bg-gradient-to-br from-[#FBFAF8] to-[#F4EFE7]"
            >
              <div
                class="absolute w-60 h-60 rounded-full bg-[#E9D8B4]/50 blur-[90px]"
              ></div>

              <img
                src="<%= item.image %>"
                alt="<%= item.name %>"
                class="relative z-10 max-h-[300px] object-contain transition duration-500 group-hover:scale-110"
              />
            </div>

            <!-- Product Details -->
            <div class="p-8">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-3xl font-semibold text-stone-900">
                  <%= item.name %>
                </h3>

                <span class="text-[#B68D40] text-2xl font-bold">
                  ₹<%= item.price.toLocaleString("en-IN") %>
                </span>
              </div>

              <p class="text-stone-500 leading-8 line-clamp-3">
                <%= item.description %>
              </p>

              <a
                href="/poeme-perfumery/product/<%= item._id %>"
                class="block mt-8 w-full bg-[#B68D40] hover:bg-[#9C7834] text-white py-4 rounded-full font-semibold text-center transition duration-300"
              >
                Shop Now
              </a>
            </div>
          </div>
        </div>

        <% }) %>
      </div>

      <div class="swiper-pagination mt-10"></div>

      <div class="swiper-button-prev"></div>

      <div class="swiper-button-next"></div>
    </div>

    <% } else { %>

    <div class="text-center py-20">
      <h3 class="text-3xl font-semibold text-stone-800">
        No Products Available
      </h3>

      <p class="mt-4 text-stone-500">
        Products will appear here once they are added.
      </p>
    </div>

    <% } %>
  </div>
</section>
